<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MES System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar navbar-expand-md mes-navbar">
    <div class="container-fluid">
        <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">MES System</a>
        <div class="navbar-nav ms-3">
            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            }
            <a class="nav-link @(currentController == "Dashboard" ? "active" : "")"
               asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            <a class="nav-link @(currentController == "WorkOrder" ? "active" : "")"
               asp-controller="WorkOrder" asp-action="Index">Work Orders</a>
        </div>
    </div>
</nav>

<main>
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-3 mb-0" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3 mb-0" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</main>

<footer class="mes-footer">
    MES System &mdash; Manufacturing Execution System &copy; @DateTime.Now.Year
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>