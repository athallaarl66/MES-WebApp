@using MES.Core.DTOs
@using MES.Web.Models
@model dynamic

@{
    ViewData["Title"] = "Dashboard";
    var summary = ViewBag.Summary as WorkOrderSummaryDto;
    var recent = ViewBag.RecentWorkOrders as List<WorkOrderViewModel> ?? [];

    var availability = 94.5;
    var performance = 88.2;
    var quality = 99.1;
    var oee = (availability * performance * quality) / 10000;
}

<div class="container-fluid py-4 px-4">

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h4 class="fw-semibold mb-1">Production Overview</h4>
            <p class="text-muted small mb-0">Factory Floor 01 · Line A</p>
        </div>
        <div class="health-pill">
            <span class="dot"></span> Online & syncing
        </div>
    </div>

    @if (summary == null) {
        <div class="alert-api-down mb-4">
            API connection lost — data summary tidak tersedia.
        </div>
    } else {
        <div class="row g-3 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon icon-blue">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <div class="stat-num">@oee.ToString("F1")%</div>
                    <div class="stat-label">Overall OEE</div>
                    <div class="prog-bar mt-2">
                        <div class="prog-fill prog-fill-blue" style="width: @((int)oee)%"></div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon icon-amber">
                        <i class="bi bi-cpu"></i>
                    </div>
                    <div class="stat-num">@summary.InProgress</div>
                    <div class="stat-label">Active tasks</div>
                    <div class="stat-sub">From @summary.Total total orders</div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon icon-red">
                        <i class="bi bi-stopwatch"></i>
                    </div>
                    <div class="stat-num">14.5<small class="fs-6">s</small></div>
                    <div class="stat-label">Avg cycle time</div>
                    <div class="stat-sub text-success">↑ 2.4% faster</div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon icon-green">
                        <i class="bi bi-check-all"></i>
                    </div>
                    <div class="stat-num">98.5%</div>
                    <div class="stat-label">Quality yield</div>
                    <div class="stat-sub">Last 100 units</div>
                </div>
            </div>
        </div>

        <div class="mes-card">
            <div class="mes-card-header">
                <h5>Recent production orders</h5>
                <a asp-controller="WorkOrder" asp-action="Index" class="btn-view">View all</a>
            </div>
            <div class="table-responsive">
                <table class="table table-mes mb-0">
                    <thead>
                        <tr>
                            <th>Order info</th>
                            <th>Status</th>
                            <th>Current step</th>
                            <th style="min-width: 160px">Progress</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in recent) {
                            var done  = wo.Steps.Count(s => s.Status == "done");
                            var total = wo.Steps.Count;
                            var pct   = total > 0 ? (done * 100 / total) : 0;
                            var fillClass = wo.Status == "completed" ? "prog-fill-green"
                                          : wo.Status == "failed"    ? "prog-fill-red"
                                          : "prog-fill-blue";
                            <tr>
                                <td>
                                    <div class="fw-semibold">@wo.OrderNumber</div>
                                    <div class="text-muted" style="font-size: 0.75rem">
                                        @wo.ProductName · @wo.ProductCode
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-status @GetStatusClass(wo.Status)">
                                        <span class="dot"></span>
                                        @wo.Status.Replace("_", " ")
                                    </span>
                                </td>
                                <td>@(string.IsNullOrEmpty(wo.CurrentStep) ? "—" : wo.CurrentStep)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="prog-bar flex-grow-1">
                                            <div class="prog-fill @fillClass" style="width: @pct%"></div>
                                        </div>
                                        <span class="text-muted" style="font-size:0.75rem; min-width:28px">
                                            @pct%
                                        </span>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="WorkOrder" asp-action="Detail"
                                       asp-route-id="@wo.Id" class="btn-view">
                                        Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@functions {
    string GetStatusClass(string status) => status.ToLower() switch {
        "pending"     => "status-pending",
        "in_progress" => "status-active",
        "completed"   => "status-done",
        "failed"      => "status-failed",
        _             => "status-pending"
    };
}