@using MES.Core.DTOs
@model WorkOrderSummaryDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4">

    <div class="mb-4">
        <h5 class="fw-semibold mb-0">Dashboard</h5>
        <small class="text-muted">Overview sistem produksi</small>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-warning">Gagal memuat data summary.</div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body py-4">
                        <div class="fs-1 fw-bold text-dark">@Model.Total</div>
                        <div class="text-muted small mt-1">Total Work Order</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body py-4">
                        <div class="fs-1 fw-bold text-secondary">@Model.Pending</div>
                        <div class="text-muted small mt-1">Pending</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body py-4">
                        <div class="fs-1 fw-bold text-primary">@Model.InProgress</div>
                        <div class="text-muted small mt-1">In Progress</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body py-4">
                        <div class="fs-1 fw-bold text-success">@Model.Completed</div>
                        <div class="text-muted small mt-1">Completed</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <a asp-controller="WorkOrder" asp-action="Index"
               class="btn btn-outline-dark btn-sm px-4">
                Lihat Semua Work Order →
            </a>
        </div>
    }
</div>