@model MES.Web.Models.WorkOrderViewModel

@{
    ViewData["Title"] = $"Detail - {Model.OrderNumber}";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-0 fw-semibold">@Model.OrderNumber</h5>
            <small class="text-muted">@Model.ProductName · @Model.ProductCode</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Logs" asp-route-id="@Model.Id"
               class="btn btn-outline-secondary btn-sm">📋 Activity Log</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Kembali</a>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0">Informasi Work Order</h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted small" style="width:40%">Order Number</td>
                            <td class="fw-semibold">@Model.OrderNumber</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Produk</td>
                            <td>@Model.ProductName</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Kode</td>
                            <td>@Model.ProductCode</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Quantity</td>
                            <td>@Model.Quantity</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Status</td>
                            <td>
                                <span class="badge @GetStatusClass(Model.Status)">
                                    @GetStatusLabel(Model.Status)
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Step Saat Ini</td>
                            <td class="fw-semibold">@Model.CurrentStep</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Dibuat</td>
                            <td class="small">
                                @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Step Produksi</h6>
                    <small class="text-white-50">
                        @Model.Steps.Count(s => s.Status == "done") / @Model.Steps.Count step selesai
                    </small>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:5%">#</th>
                                <th>Step</th>
                                <th>Status</th>
                                <th>Operator</th>
                                <th>Mulai</th>
                                <th>Selesai</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Steps)
                            {
                                <tr class="@(step.Status == "in_progress" ? "table-primary" : step.Status == "failed" ? "table-danger" : "")">
                                    <td class="text-muted small">@step.StepOrder</td>
                                    <td class="fw-semibold">@step.StepName</td>
                                    <td>
                                        <span class="badge @GetStepClass(step.Status)">
                                            @GetStepLabel(step.Status)
                                        </span>
                                    </td>
                                    <td class="text-muted small">@(step.ExecutedBy ?? "-")</td>
                                    <td class="text-muted small">
                                        @(step.StartedAt.HasValue
                                            ? step.StartedAt.Value.ToLocalTime().ToString("dd MMM HH:mm")
                                            : "-")
                                    </td>
                                    <td class="text-muted small">
                                        @(step.CompletedAt.HasValue
                                            ? step.CompletedAt.Value.ToLocalTime().ToString("dd MMM HH:mm")
                                            : "-")
                                    </td>
                                    <td>
                                        @if (step.Status == "in_progress")
                                        {
                                            <form asp-controller="Step" asp-action="Finish"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="workOrderId" value="@Model.Id" />
                                                <button type="submit" name="stepExecutionId"
                                                        value="@step.Id"
                                                        class="btn btn-success btn-sm">
                                                    ✓ Finish
                                                </button>
                                            </form>

                                            @if (step.StepName == "Quality Check")
                                            {
                                                <form asp-controller="Step" asp-action="FailQc"
                                                      method="post" class="d-inline ms-1">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="workOrderId" value="@Model.Id" />
                                                    <input type="hidden" name="reason" value="QC tidak lolos" />
                                                    <button type="submit" name="stepExecutionId"
                                                            value="@step.Id"
                                                            class="btn btn-danger btn-sm">
                                                        ✗ Fail QC
                                                    </button>
                                                </form>
                                            }
                                        }
                                        else if (step.CanStart)
                                        {
                                            <form asp-controller="Step" asp-action="Start"
                                                  method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="workOrderId" value="@Model.Id" />
                                                <button type="submit" name="stepExecutionId"
                                                        value="@step.Id"
                                                        class="btn btn-primary btn-sm">
                                                    ▶ Start
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@functions {
    string GetStatusClass(string status) => status switch
    {
        "pending"     => "badge-pending",
        "in_progress" => "badge-in-progress",
        "completed"   => "badge-done",
        "cancelled"   => "badge-failed",
        _             => "badge-pending"
    };

    string GetStatusLabel(string status) => status switch
    {
        "pending"     => "Pending",
        "in_progress" => "In Progress",
        "completed"   => "Completed",
        "cancelled"   => "Cancelled",
        _             => status
    };

    string GetStepClass(string status) => status switch
    {
        "pending"     => "badge-pending",
        "in_progress" => "badge-in-progress",
        "done"        => "badge-done",
        "failed"      => "badge-failed",
        _             => "badge-pending"
    };

    string GetStepLabel(string status) => status switch
    {
        "pending"     => "Pending",
        "in_progress" => "In Progress",
        "done"        => "Done",
        "failed"      => "Failed",
        _             => status
    };
}