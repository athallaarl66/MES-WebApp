@model MES.Web.Models.WorkOrderViewModel
@{ ViewData["Title"] = $"Detail - {Model.OrderNumber}"; }

<div class="page-header">
    <div class="container-fluid px-0 d-flex justify-content-between align-items-center">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a asp-action="Index" class="breadcrumb-link">Work Orders</a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current">@Model.OrderNumber</span>
            </div>
            <h5>@Model.OrderNumber</h5>
            <div class="subtitle">@Model.ProductName &middot; @Model.ProductCode</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Logs" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
                Activity Log
            </a>
            <a asp-action="Index" class="btn btn-outline-dark btn-sm">← Kembali</a>
        </div>
    </div>
</div>

<div class="container-fluid px-4">

    <div class="step-track">
        @foreach (var step in Model.Steps)
        {
            var itemClass = step.Status == "done"        ? "step-done"
                          : step.Status == "in_progress" ? "step-active"
                          : step.Status == "failed"      ? "step-failed"
                          : "";
            var dotLabel  = step.Status == "done"   ? "✓"
                          : step.Status == "failed" ? "✕"
                          : step.StepOrder.ToString();
            <div class="step-item @itemClass">
                <div class="step-dot">@dotLabel</div>
                <div class="step-label">@step.StepName</div>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">Detail Informasi</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <td class="ps-3 py-2 text-muted">Quantity</td>
                                <td class="fw-semibold text-end pe-3 py-2">@Model.Quantity</td>
                            </tr>
                            <tr>
                                <td class="ps-3 py-2 text-muted">Status WO</td>
                                <td class="text-end pe-3 py-2">
                                    <span class="badge @GetStatusBadge(Model.Status)">
                                        @GetStatusLabel(Model.Status)
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-3 py-2 text-muted">Step Aktif</td>
                                <td class="fw-semibold text-end pe-3 py-2">
                                    @(string.IsNullOrEmpty(Model.CurrentStep) ? "—" : Model.CurrentStep)
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-3 py-2 text-muted">Dibuat</td>
                                <td class="text-end pe-3 py-2 text-muted" style="font-size:0.8rem">
                                    @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">Daftar Task Produksi</div>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">#</th>
                                <th>Nama Step</th>
                                <th>Status</th>
                                <th>Operator</th>
                                <th class="text-end pe-3">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Steps)
                            {
                                <tr id="row-@step.Id">
                                    <td class="ps-3 text-muted">@step.StepOrder</td>
                                    <td class="fw-semibold">@step.StepName</td>
                                    <td>
                                        <span class="badge @GetStepBadge(step.Status)">
                                            @GetStepLabel(step.Status)
                                        </span>
                                    </td>
                                    <td class="text-muted">@(step.ExecutedBy ?? "—")</td>
                                    <td class="text-end pe-3">
                                        @if (step.Status == "in_progress")
                                        {
                                            @if (step.CanPassQc)
                                            {
                                                <button onclick="handleAction(this, @step.Id, 'pass-qc')"
                                                        class="btn btn-sm btn-teal ms-1">
                                                    Pass QC
                                                </button>
                                            }
                                            @if (step.CanFailQc)
                                            {
                                                <button onclick="openFailQcModal(@step.Id)"
                                                        class="btn btn-danger btn-sm ms-1">
                                                    Fail QC
                                                </button>
                                            }
                                            @if (!step.CanPassQc && !step.CanFailQc)
                                            {
                                                <button onclick="handleAction(this, @step.Id, 'finish')"
                                                        class="btn btn-success btn-sm px-3">
                                                    Finish
                                                </button>
                                            }
                                        }
                                        else if (step.CanStart)
                                        {
                                            <button onclick="handleAction(this, @step.Id, 'start')"
                                                    class="btn btn-primary btn-sm px-3">
                                                Start
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size:0.8rem">Locked</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="failQcModal" tabindex="-1" aria-labelledby="failQcModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="failQcModalLabel">Konfirmasi QC Gagal</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">
                    Step akan dikembalikan ke Assembly. Tuliskan alasan kegagalan QC.
                </p>
                <label for="failReason" class="form-label">Alasan Kegagalan</label>
                <textarea id="failReason" class="form-control" rows="3"
                          placeholder="Contoh: Dimensi tidak sesuai toleransi"></textarea>
                <div id="failReasonError" class="text-danger small mt-1 d-none">
                    Alasan wajib diisi.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-dark btn-sm" data-bs-dismiss="modal">
                    Batal
                </button>
                <button type="button" class="btn btn-danger btn-sm px-3" onclick="submitFailQc()">
                    Konfirmasi Gagal
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let activeFailQcStepId = null;
    const failQcModal = new bootstrap.Modal(document.getElementById('failQcModal'));

    function openFailQcModal(stepId) {
        activeFailQcStepId = stepId;
        document.getElementById('failReason').value = '';
        document.getElementById('failReasonError').classList.add('d-none');
        failQcModal.show();
    }

    async function submitFailQc() {
        const reason = document.getElementById('failReason').value.trim();
        if (!reason) {
            document.getElementById('failReasonError').classList.remove('d-none');
            return;
        }
        failQcModal.hide();
        const btn = document.querySelector(`#row-${activeFailQcStepId} .btn-danger`);
        await handleAction(btn, activeFailQcStepId, 'fail-qc', reason);
    }

    async function handleAction(btn, stepId, action, reason = null) {
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';

        try {
            const body = action === 'fail-qc' ? JSON.stringify({ reason }) : null;
            const response = await fetch(`/api/steps/${stepId}/${action}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body
            });

            const result = await response.json();

            if (result.success) {
                location.reload();
            } else {
                showToast(result.message || 'Gagal memproses data.');
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        } catch {
            showToast('Terjadi kesalahan jaringan.');
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    }

    function showToast(message, type = 'error') {
        const existing = document.getElementById('mes-toast');
        if (existing) existing.remove();

        const isError = type === 'error';
        const toast = document.createElement('div');
        toast.id = 'mes-toast';
        toast.className = isError ? 'mes-toast mes-toast-error' : 'mes-toast mes-toast-success';
        toast.textContent = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }
</script>
}

@functions {
    string GetStatusBadge(string s) => s switch {
        "in_progress" => "badge-status-active",
        "completed"   => "badge-status-done",
        "cancelled"   => "badge-status-cancelled",
        _             => "badge-status-pending"
    };
    string GetStatusLabel(string s) => s switch {
        "pending"     => "Pending",
        "in_progress" => "In Progress",
        "completed"   => "Completed",
        "cancelled"   => "Cancelled",
        _             => s
    };
    string GetStepBadge(string s) => s switch {
        "done"        => "badge-status-done",
        "in_progress" => "badge-status-active",
        "failed"      => "badge-status-failed",
        _             => "badge-status-pending"
    };
    string GetStepLabel(string s) => s switch {
        "done"        => "Done",
        "in_progress" => "In Progress",
        "failed"      => "Failed",
        _             => "Pending"
    };
}