@model MES.Web.Models.WorkOrderViewModel
@{ ViewData["Title"] = $"Detail - {Model.OrderNumber}"; }

<div class="page-header border-bottom pb-3 mb-4">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Work Orders</a></li>
                    <li class="breadcrumb-item active">@Model.OrderNumber</li>
                </ol>
            </nav>
            <h4 class="mb-0">@Model.OrderNumber</h4>
            <small class="text-muted">@Model.ProductName (@Model.ProductCode)</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Logs" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">📋 Activity Log</a>
            <a asp-action="Index" class="btn btn-light btn-sm border">← Kembali</a>
        </div>
    </div>
</div>

<div class="container-fluid">
    @* Progress Track *@
    <div class="card mb-4 shadow-sm border-0 bg-light">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between">
                @foreach (var step in Model.Steps) {
                    var statusClass = step.Status == "done" ? "text-success" : step.Status == "in_progress" ? "text-primary fw-bold" : "text-muted";
                    <div class="text-center" style="flex: 1;">
                        <div class="mb-1">@(step.Status == "done" ? "✅" : step.Status == "in_progress" ? "🔵" : "⚪")</div>
                        <div class="small @statusClass">@step.StepName</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* Info WO *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">Detail Informasi</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tbody class="small">
                            <tr><td class="text-muted ps-3 py-2">Quantity</td><td class="fw-bold text-end pe-3 py-2">@Model.Quantity</td></tr>
                            <tr><td class="text-muted ps-3 py-2">Status WO</td><td class="text-end pe-3 py-2"><span class="badge @GetStatusClass(Model.Status)">@GetStatusLabel(Model.Status)</span></td></tr>
                            <tr><td class="text-muted ps-3 py-2">Step Aktif</td><td class="fw-bold text-end pe-3 py-2">@Model.CurrentStep</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* Table Steps *@
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-bold">Daftar Task Produksi</div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light small text-uppercase">
                            <tr>
                                <th class="ps-3">#</th>
                                <th>Nama Step</th>
                                <th>Status</th>
                                <th>Operator</th>
                                <th class="text-end pe-3">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Steps) {
                                <tr id="row-@step.Id">
                                    <td class="ps-3 text-muted">@step.StepOrder</td>
                                    <td><span class="fw-bold">@step.StepName</span></td>
                                    <td><span class="badge @GetStepClass(step.Status) shadow-sm">@GetStepLabel(step.Status)</span></td>
                                    <td class="small text-muted">@(step.ExecutedBy ?? "-")</td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group-step">
                                            @if (step.Status == "in_progress") {
                                                <button onclick="handleAction(@step.Id, 'finish')" class="btn btn-success btn-sm px-3">✓ Finish</button>
                                                @if (step.CanPassQc) { <button onclick="handleAction(@step.Id, 'pass-qc')" class="btn btn-info btn-sm text-white ms-1">Pass QC</button> }
                                                @if (step.CanFailQc) { <button onclick="handleAction(@step.Id, 'fail-qc')" class="btn btn-danger btn-sm ms-1">Fail QC</button> }
                                            } else if (step.CanStart) {
                                                <button onclick="handleAction(@step.Id, 'start')" class="btn btn-primary btn-sm px-3">▶ Start</button>
                                            } else {
                                                <span class="text-muted small">Locked</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function handleAction(id, action) {
        const btn = event.target;
        const originalText = btn.innerText;
        let reason = "";

        if (action === 'fail-qc') {
            reason = prompt("Masukkan alasan kegagalan QC:"); // Rule: Custom dialog next
            if (!reason) return;
        }

        // Rule: UI Logic - Disable while loading
        btn.disabled = true;
        btn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status"></span>`;

        try {
            // Kita panggil langsung ke API URL. Sesuaikan base URL jika perlu.
            const response = await fetch(`/api/steps/${id}/${action}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: action === 'fail-qc' ? JSON.stringify({ reason: reason }) : null
            });

            const result = await response.json();

            if (result.success) {
                location.reload(); 
            } else {
                // Rule: Sanitized error message from Backend
                alert(result.message || "Gagal memproses data.");
                btn.disabled = false;
                btn.innerText = originalText;
            }
        } catch (error) {
            alert("Terjadi kesalahan sistem atau jaringan.");
            btn.disabled = false;
            btn.innerText = originalText;
        }
    }
</script>
}

@functions {
    string GetStatusClass(string s) => s == "completed" ? "bg-success" : s == "in_progress" ? "bg-primary" : "bg-secondary";
    string GetStatusLabel(string s) => s == "in_progress" ? "Dalam Proses" : s == "completed" ? "Selesai" : "Menunggu";
    string GetStepClass(string s) => s == "done" ? "bg-success" : s == "in_progress" ? "bg-primary" : s == "failed" ? "bg-danger" : "bg-light text-dark border";
    string GetStepLabel(string s) => s == "done" ? "Done" : s == "in_progress" ? "In Progress" : s == "failed" ? "Fail" : "Pending";
}