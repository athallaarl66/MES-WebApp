@model List<MES.Web.Models.WorkOrderViewModel>

@{
    ViewData["Title"] = "Work Orders";
}

<div class="page-header">
    <div class="container-fluid px-0 d-flex justify-content-between align-items-center">
        <div>
            <h5>Work Orders</h5>
            <div class="subtitle">@Model.Count work order ditemukan</div>
        </div>
        <a asp-action="Create" class="btn btn-dark btn-sm px-3">+ Buat Work Order</a>
    </div>
</div>

<div class="container-fluid px-4">
    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <div style="font-size:2.5rem;margin-bottom:1rem">📋</div>
                <div class="fw-semibold mb-1" style="color:#0f172a">Belum ada work order</div>
                <div class="text-muted small mb-3">Mulai dengan membuat work order pertama</div>
                <a asp-action="Create" class="btn btn-dark btn-sm px-4">+ Buat Work Order</a>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Order Number</th>
                            <th>Produk</th>
                            <th>Kode</th>
                            <th class="text-center">Qty</th>
                            <th>Status</th>
                            <th>Step Saat Ini</th>
                            <th>Dibuat</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in Model)
                        {
                            <tr>
                                <td class="fw-semibold" style="color:#0f172a">@wo.OrderNumber</td>
                                <td>@wo.ProductName</td>
                                <td style="color:#94a3b8">@wo.ProductCode</td>
                                <td class="text-center">@wo.Quantity</td>
                                <td><span class="badge @GetStatusClass(wo.Status)">@GetStatusLabel(wo.Status)</span></td>
                                <td style="color:#64748b">@wo.CurrentStep</td>
                                <td style="color:#94a3b8;font-size:0.8rem">
                                    @wo.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </td>
                                <td>
                                    <a asp-action="Detail" asp-route-id="@wo.Id"
                                       class="btn btn-outline-dark btn-sm">Detail →</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@functions {
    string GetStatusClass(string status) => status switch
    {
        "pending"     => "badge-pending",
        "in_progress" => "badge-in-progress",
        "completed"   => "badge-done",
        "cancelled"   => "badge-failed",
        _             => "badge-pending"
    };
    string GetStatusLabel(string status) => status switch
    {
        "pending"     => "Pending",
        "in_progress" => "In Progress",
        "completed"   => "Completed",
        "cancelled"   => "Cancelled",
        _             => status
    };
}