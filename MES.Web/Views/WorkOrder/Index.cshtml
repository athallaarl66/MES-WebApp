@model List<MES.Web.Models.WorkOrderViewModel>
@{ ViewData["Title"] = "Work Orders"; }

<div class="page-header">
    <div class="container-fluid px-0 d-flex justify-content-between align-items-center">
        <div>
            <h5>Work Orders</h5>
            <div class="subtitle">@Model.Count work order ditemukan</div>
        </div>
        <a asp-action="Create" class="btn btn-dark btn-sm px-3">+ Buat Work Order</a>
    </div>
</div>

<div class="container-fluid px-4">
    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <div class="mb-2" style="font-size:2rem; color:#cbd5e1">&#9634;</div>
                <div class="fw-semibold mb-1">Belum ada work order</div>
                <div class="text-muted small mb-3">Mulai dengan membuat work order pertama</div>
                <a asp-action="Create" class="btn btn-dark btn-sm px-4">+ Buat Work Order</a>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Order Number</th>
                            <th>Produk</th>
                            <th>Kode</th>
                            <th class="text-center">Qty</th>
                            <th>Status</th>
                            <th>Step Saat Ini</th>
                            <th>Dibuat</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@wo.OrderNumber</td>
                                <td>@wo.ProductName</td>
                                <td class="text-muted">@wo.ProductCode</td>
                                <td class="text-center">@wo.Quantity</td>
                                <td>
                                    <span class="badge @GetStatusBadge(wo.Status)">
                                        @GetStatusLabel(wo.Status)
                                    </span>
                                </td>
                                <td class="text-muted">
                                    @(string.IsNullOrEmpty(wo.CurrentStep) ? "—" : wo.CurrentStep)
                                </td>
                                <td class="text-muted" style="font-size:0.8rem; white-space:nowrap">
                                    @(wo.CreatedAt == default ? "—" : wo.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm"))
                                </td>
                                <td>
                                    <a asp-action="Detail" asp-route-id="@wo.Id"
                                       class="btn btn-outline-dark btn-sm">
                                        Detail →
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@functions {
    string GetStatusBadge(string status) => status switch {
        "in_progress" => "badge-status-active",
        "completed"   => "badge-status-done",
        "cancelled"   => "badge-status-cancelled",
        _             => "badge-status-pending"
    };
    string GetStatusLabel(string status) => status switch {
        "pending"     => "Pending",
        "in_progress" => "In Progress",
        "completed"   => "Completed",
        "cancelled"   => "Cancelled",
        _             => status
    };
}