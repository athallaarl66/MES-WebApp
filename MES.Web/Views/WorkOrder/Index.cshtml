@model List<MES.Web.Models.WorkOrderViewModel>

@{
    ViewData["Title"] = "Work Orders";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-0 fw-semibold">Work Orders</h5>
            <small class="text-muted">@Model.Count work order ditemukan</small>
        </div>
        <a asp-action="Create" class="btn btn-dark btn-sm px-3">+ Buat Work Order</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="text-muted mb-3" style="font-size: 2rem;">📋</div>
                <p class="text-muted mb-3">Belum ada work order.</p>
                <a asp-action="Create" class="btn btn-dark btn-sm px-4">Buat Work Order Pertama</a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Order Number</th>
                            <th>Produk</th>
                            <th>Kode</th>
                            <th class="text-center">Qty</th>
                            <th>Status</th>
                            <th>Step Saat Ini</th>
                            <th>Dibuat</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wo in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@wo.OrderNumber</td>
                                <td>@wo.ProductName</td>
                                <td class="text-muted small">@wo.ProductCode</td>
                                <td class="text-center">@wo.Quantity</td>
                                <td>
                                    <span class="badge @GetStatusClass(wo.Status)">
                                        @GetStatusLabel(wo.Status)
                                    </span>
                                </td>
                                <td class="text-muted small">@wo.CurrentStep</td>
                                <td class="text-muted small">
                                    @wo.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </td>
                                <td>
                                    <a asp-action="Detail" asp-route-id="@wo.Id"
                                       class="btn btn-outline-dark btn-sm">Detail →</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@functions {
    string GetStatusClass(string status) => status switch
    {
        "pending"     => "badge-pending",
        "in_progress" => "badge-in-progress",
        "completed"   => "badge-done",
        "cancelled"   => "badge-failed",
        _             => "badge-pending"
    };

    string GetStatusLabel(string status) => status switch
    {
        "pending"     => "Pending",
        "in_progress" => "In Progress",
        "completed"   => "Completed",
        "cancelled"   => "Cancelled",
        _             => status
    };
}