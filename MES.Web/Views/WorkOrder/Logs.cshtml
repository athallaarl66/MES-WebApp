@using MES.Core.DTOs
@model List<ActivityLogDto>

@{
    var workOrder = ViewBag.WorkOrder as MES.Web.Models.WorkOrderViewModel;
    ViewData["Title"] = $"Activity Log - {workOrder?.OrderNumber}";
}

<div class="page-header">
    <div class="container-fluid px-0 d-flex justify-content-between align-items-center">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a asp-controller="WorkOrder" asp-action="Index" class="breadcrumb-link">Work Orders</a>
                <span class="breadcrumb-sep">/</span>
                <a asp-action="Detail" asp-route-id="@workOrder?.Id" class="breadcrumb-link">
                    @workOrder?.OrderNumber
                </a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current">Activity Log</span>
            </div>
            <h5>Activity Log</h5>
            <div class="subtitle">@workOrder?.OrderNumber &middot; @workOrder?.ProductName</div>
        </div>
        <a asp-action="Detail" asp-route-id="@workOrder?.Id" class="btn btn-outline-dark btn-sm">
            ← Kembali
        </a>
    </div>
</div>

<div class="container-fluid px-4">
    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <div class="mb-2" style="font-size: 1.75rem; color: #cbd5e1;">&#9635;</div>
                <div class="text-muted">Belum ada aktivitas tercatat.</div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Log Aktivitas</span>
                <span style="font-size: 0.75rem; color: #94a3b8;">@Model.Count entri</span>
            </div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Waktu</th>
                            <th>Step</th>
                            <th>Action</th>
                            <th>Notes</th>
                            <th>Operator</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td style="color: #94a3b8; font-size: 0.8rem; white-space: nowrap;">
                                    @log.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")
                                </td>
                                <td style="color: #64748b;">@(log.StepName ?? "—")</td>
                                <td>
                                    <span class="badge @GetActionBadge(log.Action)">
                                        @GetActionLabel(log.Action)
                                    </span>
                                </td>
                                <td style="color: #64748b;">@(log.Notes ?? "—")</td>
                                <td class="fw-semibold">@log.CreatedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@functions {
    string GetActionBadge(string action) => action switch
    {
        "step_started"       => "badge-status-active",
        "step_completed"     => "badge-status-done",
        "qc_failed"          => "badge-status-failed",
        "work_order_created" => "badge-status-pending",
        _                    => "badge-status-pending"
    };
    string GetActionLabel(string action) => action switch
    {
        "step_started"       => "Step Started",
        "step_completed"     => "Step Completed",
        "qc_failed"          => "QC Failed",
        "work_order_created" => "WO Created",
        _                    => action
    };
}