@model MES.Web.Models.CreateWorkOrderViewModel

@{
    ViewData["Title"] = "Buat Work Order";
}

<div class="page-header">
    <div class="container-fluid px-0 d-flex justify-content-between align-items-center">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a asp-action="Index" style="color:#94a3b8;font-size:0.8rem;text-decoration:none">Work Orders</a>
                <span style="color:#cbd5e1;font-size:0.8rem">/</span>
                <span style="font-size:0.8rem;color:#64748b">Buat Baru</span>
            </div>
            <h5>Buat Work Order</h5>
            <div class="subtitle">Isi form di bawah untuk membuat work order baru</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-dark btn-sm">← Kembali</a>
    </div>
</div>

<div class="container-fluid px-4">
    <div class="row justify-content-start">
        <div class="col-md-6 col-lg-5">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="OrderNumber" class="form-label">Order Number</label>
                            <input asp-for="OrderNumber" class="form-control" placeholder="Contoh: WO-2024-001" />
                            <span asp-validation-for="OrderNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductName" class="form-label">Nama Produk</label>
                            <input asp-for="ProductName" class="form-control" placeholder="Contoh: Gear Assembly Type A" />
                            <span asp-validation-for="ProductName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductCode" class="form-label">Kode Produk</label>
                            <input asp-for="ProductCode" class="form-control" placeholder="Contoh: GA-TYPE-A" />
                            <span asp-validation-for="ProductCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Quantity" class="form-label">Quantity</label>
                            <input asp-for="Quantity" type="number" min="1" class="form-control" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark px-4">Buat Work Order</button>
                            <a asp-action="Index" class="btn btn-outline-dark px-4">Batal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}