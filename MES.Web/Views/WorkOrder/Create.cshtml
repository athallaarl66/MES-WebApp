@model MES.Web.Models.CreateWorkOrderViewModel

@{
    ViewData["Title"] = "Buat Work Order";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0">Buat Work Order Baru</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="OrderNumber" class="form-label fw-semibold">Order Number</label>
                            <input asp-for="OrderNumber" class="form-control" placeholder="Contoh: WO-2024-001" />
                            <span asp-validation-for="OrderNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductName" class="form-label fw-semibold">Nama Produk</label>
                            <input asp-for="ProductName" class="form-control" placeholder="Contoh: Gear Assembly Type A" />
                            <span asp-validation-for="ProductName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductCode" class="form-label fw-semibold">Kode Produk</label>
                            <input asp-for="ProductCode" class="form-control" placeholder="Contoh: GA-TYPE-A" />
                            <span asp-validation-for="ProductCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Quantity" class="form-label fw-semibold">Quantity</label>
                            <input asp-for="Quantity" type="number" min="1" class="form-control" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark px-4">Buat Work Order</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Batal</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}